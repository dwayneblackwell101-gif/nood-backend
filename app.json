{
  "expo": {
    "name": "NOOD",
    "slug": "nood-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/nood-brand-logo.png",
    "scheme": "shop.66320990292.nood",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.noodcaribbean.app",
      "infoPlist": {
        "NSCameraUsageDescription": "NOOD uses the camera for visual product search and scanning product photos.",
        "NSPhotoLibraryUsageDescription": "NOOD uses your photo library so you can choose a profile picture or search products by image.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLName": "com.noodcaribbean.app.shopify-auth",
            "CFBundleURLSchemes": [
              "shop.66320990292.nood"
            ]
          }
        ]
      }
    },
    "android": {
      "predictiveBackGestureEnabled": false,
      "package": "com.noodcaribbean.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [
            {
              "scheme": "shop.66320990292.nood",
              "host": "auth",
              "pathPrefix": "/callback"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-notifications",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/nood-splash-logo.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#ffffff"
          }
        }
      ],
      "expo-localization",
      "expo-video",
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "NOOD uses the camera so you can take a photo and search products by image."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "NOOD uses your photo library so you can choose a profile picture or search products by image."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "20a1823c-474f-43d7-9b39-aed139d50629"
      }
    },
    "owner": "noodcaribbean"
  }
}
