NODE_ENV=test
PORT=0
BACKEND_BASE_URL=http://127.0.0.1:0
SHOPIFY_CURRENCY=USD
PAYMENT_CURRENCY=USD
WALLET_CURRENCY=USD
PAYPAL_ENABLED=false
WIPAY_ENABLED=false
LOCAL_STATE_FALLBACK_ENABLED=true
NOOD_DISABLE_BACKGROUND_WORKERS=true
NOOD_CATALOG_FORCE_JSON=1
REDIS_NAMESPACE=nood_test
PAYMENT_LOCK_TTL_SECONDS=5
CATALOG_SYNC_LOCK_TTL_SECONDS=30
SHOPIFY_STORE_DOMAIN=test-store.example
SHOPIFY_STOREFRONT_ACCESS_TOKEN=fake_storefront_token
SHOPIFY_ADMIN_ACCESS_TOKEN=fake_admin_token
SHOPIFY_ORDER_ADMIN_ACCESS_TOKEN=fake_order_admin_token
SHOPIFY_WEBHOOK_SECRET=fake_webhook_secret
ADMIN_API_KEY=fake_admin_key
NOOD_ADMIN_API_KEY=fake_nood_admin_key
