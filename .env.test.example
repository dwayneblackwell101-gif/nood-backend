NODE_ENV=test
PORT=0
BACKEND_BASE_URL=http://127.0.0.1:0
SHOPIFY_CURRENCY=USD
PAYMENT_CURRENCY=USD
WALLET_CURRENCY=USD
PAYPAL_ENABLED=false
WIPAY_ENABLED=false
LOCAL_STATE_FALLBACK_ENABLED=true
NOOD_DISABLE_BACKGROUND_WORKERS=true
NOOD_CATALOG_FORCE_JSON=1
REDIS_NAMESPACE=nood_test
PAYMENT_LOCK_TTL_SECONDS=5
CATALOG_SYNC_LOCK_TTL_SECONDS=30
CATALOG_SYNC_LOCK_RENEW_SECONDS=10
CATALOG_MAX_COUNT_DROP_PERCENT=100
CATALOG_MIN_PRODUCT_COUNT=0
CATALOG_VERSION_RETENTION_COUNT=3
CATALOG_FAILED_VERSION_RETENTION_DAYS=1
CATALOG_SCHEMA_VERSION=1
CATALOG_LEGACY_FALLBACK_ENABLED=true
SHOPIFY_STORE_DOMAIN=test-store.example
SHOPIFY_STOREFRONT_ACCESS_TOKEN=fake_storefront_token
SHOPIFY_ADMIN_ACCESS_TOKEN=fake_admin_token
SHOPIFY_ORDER_ADMIN_ACCESS_TOKEN=fake_order_admin_token
SHOPIFY_WEBHOOK_SECRET=fake_webhook_secret
SHOPIFY_WEBHOOK_BODY_LIMIT=2mb
SHOPIFY_WEBHOOKS_REQUIRED=true
WEBHOOK_JOB_LEASE_SECONDS=60
WEBHOOK_RETRY_BASE_SECONDS=5
WEBHOOK_RETRY_MAX_SECONDS=900
WEBHOOK_MAX_ATTEMPTS=8
WEBHOOK_WORKER_POLL_MS=1000
WEBHOOK_WORKER_HEARTBEAT_SECONDS=15
WEBHOOK_WORKER_STALE_SECONDS=60
WEBHOOK_COMPLETED_RETENTION_SECONDS=604800
WEBHOOK_DEAD_LETTER_RETENTION_SECONDS=2592000
ADMIN_API_KEY=fake_admin_key
NOOD_ADMIN_API_KEY=fake_nood_admin_key
