NODE_ENV=development
PORT=3000
LOCAL_IP=192.168.0.6
BACKEND_BASE_URL=http://192.168.0.6:3000
APP_DEEP_LINK_SCHEME=noodapp
ADMIN_API_KEY=your_admin_api_key
NOOD_ADMIN_API_KEY=your_admin_api_key
# Sync auth headers (send one):
# x-nood-admin-api-key: <NOOD_ADMIN_API_KEY>
# x-admin-key: <ADMIN_API_KEY>
NOOD_ALLOWED_ORIGINS=https://www.noodcaribbean.com,https://noodcaribbean.com
STORAGE_DRIVER=json
REQUEST_BODY_LIMIT=1mb
NOTIFICATION_SEND_RATE_LIMIT=10

# Redis (Upstash in production). Leave empty for local JSON file cache fallback.
REDIS_URL=

WIPAY_ACCOUNT_NUMBER=your_wipay_account_number
WIPAY_API_KEY=your_wipay_api_key
# Use sandbox for WiPay test cards. Aliases also supported: WIPAY_ENV, WIPAY_MODE
WIPAY_ENVIRONMENT=sandbox

PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_ENV=sandbox
PAYPAL_CURRENCY=USD
SHOPIFY_CURRENCY=USD
WALLET_CURRENCY=USD
PAYMENT_CURRENCY=USD
PAYPAL_ENABLED=true
WIPAY_ENABLED=false
WIPAY_TRANSACTION_CURRENCY=USD
WIPAY_CURRENCY_CONVERSION_ENABLED=false
EXCHANGE_RATE_PROVIDER=
EXCHANGE_RATE_MAX_AGE_SECONDS=3600
LOCAL_STATE_FALLBACK_ENABLED=true
REDIS_NAMESPACE=nood
PAYMENT_LOCK_TTL_SECONDS=60
WALLET_LOCK_TTL_SECONDS=30
PENDING_PAYMENT_TTL_SECONDS=604800

SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=your_shopify_admin_access_token
# Required for paid checkout order creation. Must include write_orders. Do not reuse the catalog token.
SHOPIFY_ORDER_ADMIN_ACCESS_TOKEN=your_shopify_order_admin_access_token
# Admin token must include read_discounts scope for GET /api/discounts
SHOPIFY_ADMIN_API_VERSION=2025-10
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_shopify_storefront_access_token
SHOPIFY_STOREFRONT_API_VERSION=2025-10
SHOPIFY_WEBHOOK_SECRET=your_shopify_webhook_signing_secret
SHOPIFY_WEBHOOK_BODY_LIMIT=2mb
SHOPIFY_WEBHOOKS_REQUIRED=true
WEBHOOK_JOB_LEASE_SECONDS=60
WEBHOOK_RETRY_BASE_SECONDS=5
WEBHOOK_RETRY_MAX_SECONDS=900
WEBHOOK_MAX_ATTEMPTS=8
WEBHOOK_WORKER_POLL_MS=1000
WEBHOOK_WORKER_HEARTBEAT_SECONDS=15
WEBHOOK_WORKER_STALE_SECONDS=60
WEBHOOK_COMPLETED_RETENTION_SECONDS=604800
WEBHOOK_DEAD_LETTER_RETENTION_SECONDS=2592000
